{
  "name": "hmpps-esupervision-e2e-tests",
  "version": "1.0.0",
  "description": "Playwright E2E tests for online check ins and eSupervision user journeys",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:mpop && npm run test:e2e && npm run test:parallel",
    "test:e2e": "ENV=test playwright test src/tests/e2e --workers=1 --retries=0",
    "test:mpop": "ENV=dev playwright test src/tests/mpop --workers=1",
    "test:parallel": "ENV=dev playwright test src/tests/checkin src/tests/static",
    "test:headed": "ENV=test playwright test --headed",
    "test:mpop:headed": "ENV=dev playwright test src/tests/mpop --workers=1 --headed",
    "test:e2e:headed": "ENV=test playwright test src/tests/e2e --workers=1 --headed",
    "cleanup:crns": "ENV=test tsx src/scripts/cleanupCrns.ts",
    "cleanup:crns:headed": "ENV=test HEADED=true tsx src/scripts/cleanupCrns.ts",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ministryofjustice/hmpps-esupervision-e2e-tests.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/ministryofjustice/hmpps-esupervision-e2e-tests/issues"
  },
  "homepage": "https://github.com/ministryofjustice/hmpps-esupervision-e2e-tests#readme",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@ministryofjustice/hmpps-probation-integration-e2e-tests": "^1.207.0",
    "@playwright/test": "^1.60.0",
    "@types/luxon": "^3.4.2",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.0.1",
    "@typescript-eslint/parser": "^8.0.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "luxon": "^3.5.0"
  }
}
